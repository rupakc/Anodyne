# Copy to .env and fill in ANODYNE_SECRET_KEY before running `make migrate` /
# `make seed` / the api-gateway app locally. Values below match the backbone
# started by `make up` (infra/docker/docker-compose.yml) and the demo realm
# (infra/docker/keycloak/anodyne-realm.json).
#
# Two different Postgres roles are in play (see
# infra/docker/postgres/init/01-app-role.sql and docs/dev-runbook.md):
#   - `postgres`    : bootstrap SUPERUSER, owns the tables. Used ONLY by
#                     Alembic (ANODYNE_DB_DSN) to create/alter schema and RLS
#                     policies during `make migrate`.
#   - `anodyne_app` : non-superuser role the app/seed script connects as at
#                     runtime (ANODYNE_DATABASE_URL). Superusers bypass
#                     row-level security even with FORCE ROW LEVEL SECURITY,
#                     so the app must NOT run as `postgres`.

# Read by the api-gateway app (pydantic-settings, ANODYNE_ prefix) and by
# `make seed`. Connects as the non-superuser `anodyne_app` role so RLS is
# actually enforced.
ANODYNE_DATABASE_URL=postgresql+asyncpg://anodyne_app:anodyne_app@localhost:5432/anodyne
ANODYNE_OIDC_ISSUER=http://localhost:8080/realms/anodyne
ANODYNE_OIDC_JWKS_URL=http://localhost:8080/realms/anodyne/protocol/openid-connect/certs
ANODYNE_OIDC_AUDIENCE=anodyne
# generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
ANODYNE_SECRET_KEY=
ANODYNE_S3_BUCKET=anodyne

# Read directly by Alembic'''s env.py (bypasses the pydantic-settings prefix
# mechanism, so it'''s a separate var name pointing at the same database).
# Uses the `postgres` SUPERUSER: migrations create/own the tables and RLS
# policies, which requires owner/superuser privileges. Do NOT point the app
# runtime at this DSN.
ANODYNE_DB_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/anodyne
