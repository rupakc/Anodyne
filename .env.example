# Copy to .env and fill in ANODYNE_SECRET_KEY before running `make migrate` /
# `make seed` / the api-gateway app locally. Values below match the backbone
# started by `make up` (infra/docker/docker-compose.yml) and the demo realm
# (infra/docker/keycloak/anodyne-realm.json).

# Read by the api-gateway app (pydantic-settings, ANODYNE_ prefix).
ANODYNE_DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/anodyne
ANODYNE_OIDC_ISSUER=http://localhost:8080/realms/anodyne
ANODYNE_OIDC_JWKS_URL=http://localhost:8080/realms/anodyne/protocol/openid-connect/certs
ANODYNE_OIDC_AUDIENCE=anodyne
# generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
ANODYNE_SECRET_KEY=
ANODYNE_S3_BUCKET=anodyne

# Read directly by Alembic's env.py (bypasses the pydantic-settings prefix
# mechanism, so it's a separate var name pointing at the same database).
ANODYNE_DB_DSN=postgresql+asyncpg://app:app@localhost:5432/anodyne
